{
  "rewrites": [
    {
      "source": "/api/engine/beta/:path*",
      "destination": "https://generativelanguage.googleapis.com/:path*"
    },
    {
      "source": "/api/engine/alpha/:path*",
      "destination": "https://api.groq.com/openai/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
