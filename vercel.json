{
  "rewrites": [
    {
      "source": "/api/gemini/(.*)",
      "destination": "https://generativelanguage.googleapis.com/$1"
    },
    {
      "source": "/api/groq/(.*)",
      "destination": "https://api.groq.com/openai/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
